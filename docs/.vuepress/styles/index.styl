
// 评论区颜色重置
.gt-container
  .gt-ico-tip
    &::after
      content: '。( Win + . ) 或 ( ⌃ + ⌘ + ␣ ) 打开表情'
      color: #999
      font-size: .8rem
  .gt-meta
    border-color var(--borderColor)!important
  .gt-comments-null
    color var(--textColor)
    opacity .5
  .gt-header-textarea
    color var(--textColor)
    background rgba(180,180,180,0.1)!important
  .gt-btn
    border-color $accentColor!important
    background-color $accentColor!important
  .gt-btn-preview
    background-color rgba(255,255,255,0)!important
    color $accentColor!important
  a
    color $accentColor!important
  .gt-svg svg
    fill $accentColor!important
  .gt-comment-content,.gt-comment-admin .gt-comment-content
    background-color rgba(150,150,150,0.1)!important
    &:hover
      box-shadow 0 0 25px rgba(150,150,150,.5)!important
    .gt-comment-body
      color var(--textColor)!important


// qq徽章
.qq
  position: relative;
.qq::after
  content: "可撩";
  background: $accentColor;
  color:#fff;
  padding: 0 5px;
  border-radius: 10px;
  font-size:12px;
  position: absolute;
  top: -4px;
  right: -35px;
  transform:scale(0.85);

// demo模块图标颜色
body .vuepress-plugin-demo-block__wrapper
  &,.vuepress-plugin-demo-block__display
    border-color rgba(160,160,160,.3)
  .vuepress-plugin-demo-block__footer:hover
    .vuepress-plugin-demo-block__expand::before
      border-top-color: $accentColor !important;
      border-bottom-color: $accentColor !important;
    svg
      fill: $accentColor !important;

// 全文搜索框
.suggestions
  overflow: auto
  max-height: calc(100vh - 6rem)
  @media (max-width: 719px) {
    width: 90vw;
    min-width: 90vw!important;
    margin-right: -20px;
  }
  .highlight
    color: $accentColor
    font-weight: bold

// 个人主页
.personal-home
  background var(--bodyBg)

  .theme-vdoing-content
    max-width 1120px
    padding-top 3.6rem
    padding-bottom 4rem

    h1,
    h2,
    h3,
    p,
    ul
      letter-spacing 0

    h2
      border-bottom none
      padding-bottom 0
      margin-bottom 1rem
      color var(--textColor)

    a:hover
      text-decoration none

.profile-hero
  display grid
  grid-template-columns 220px 1fr
  gap 3rem
  align-items center
  margin 1.2rem 0 3rem
  padding 3rem
  border 1px solid var(--borderColor)
  border-radius 8px
  background var(--mainBg)
  box-shadow 0 20px 60px rgba(15, 23, 42, .08)

.profile-hero__avatar
  width 200px
  height 200px
  border-radius 50%
  padding 8px
  background linear-gradient(135deg, #2563eb, #14b8a6)
  box-shadow 0 18px 45px rgba(37, 99, 235, .24)

  img
    display block
    width 100%
    height 100%
    object-fit cover
    border-radius 50%
    background #fff

.profile-hero__eyebrow
  margin 0 0 .65rem
  color $accentColor
  font-size .86rem
  font-weight 700
  text-transform uppercase

.profile-hero__content
  h1
    margin 0
    font-size 3rem
    line-height 1.08

.profile-hero__subtitle
  margin .65rem 0 1.2rem
  color var(--textLightenColor)
  font-size 1.35rem
  font-weight 600

.profile-hero__intro
  max-width 680px
  margin 0
  color var(--textColor)
  font-size 1.05rem
  line-height 1.9

.profile-hero__actions
  display flex
  flex-wrap wrap
  gap .85rem
  margin 1.6rem 0 0

.profile-button
  display inline-flex
  align-items center
  justify-content center
  min-height 42px
  padding 0 1.1rem
  border 1px solid var(--borderColor)
  border-radius 6px
  color var(--textColor)
  font-weight 700
  background transparent
  transition all .2s ease

  &:hover
    border-color $accentColor
    color $accentColor

.profile-button--primary
  border-color $accentColor
  color #fff
  background $accentColor

  &:hover
    color #fff
    background #1d4ed8

.profile-section,
.profile-panel,
.project-card
  border 1px solid var(--borderColor)
  border-radius 8px
  background var(--mainBg)

.profile-section
  margin 0 0 1.5rem
  padding 2rem

  p
    margin 0
    line-height 1.9

.profile-grid
  display grid
  grid-template-columns repeat(2, minmax(0, 1fr))
  gap 1.5rem
  margin 0 0 1.5rem

.profile-panel
  padding 2rem

.profile-tags
  display flex
  flex-wrap wrap
  gap .75rem
  margin 0
  padding 0
  list-style none

  li
    margin 0
    padding .45rem .75rem
    border-radius 6px
    color #1e3a8a
    background rgba(37, 99, 235, .1)
    font-weight 700

.profile-list
  margin 0
  padding-left 1.2rem

  li
    margin .45rem 0
    line-height 1.7

.project-list
  display grid
  grid-template-columns repeat(3, minmax(0, 1fr))
  gap 1rem

.project-card
  padding 1.35rem

  h3
    margin-top 0
    margin-bottom .75rem

  p
    margin 0 0 1rem
    font-size .95rem

  span
    color $accentColor
    font-size .85rem
    font-weight 700

.profile-footer-cta
  text-align center

  a
    display inline-block
    margin-top 1rem
    color $accentColor
    font-weight 700

@media (max-width: 900px)
  .profile-hero
    grid-template-columns 1fr
    gap 1.6rem
    padding 2rem
    text-align center

  .profile-hero__avatar
    margin 0 auto

  .profile-hero__intro
    margin 0 auto

  .profile-hero__actions
    justify-content center

  .profile-grid,
  .project-list
    grid-template-columns 1fr

@media (max-width: 520px)
  .personal-home
    .theme-vdoing-content
      padding-top 1.4rem

  .profile-hero
    padding 1.35rem

  .profile-hero__avatar
    width 148px
    height 148px

  .profile-hero__content
    h1
      font-size 2.2rem

  .profile-section,
  .profile-panel
    padding 1.35rem
